<html>
<head>
    <title>Employee Details</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <h1>Employee Details</h1>
    <p>Name: {{employee.name}}</p>
    <img src="/images/{{employee.photo}}" width="150">
    <p>Phone: {{employee.phone}}</p>
    <a href="/edit/{{employee._id}}">Edit Details</a>

    <h2>Shifts</h2>
    {{#if shifts.length}}
    <table border="1">
        <thead>
            <tr>
                <th>Date</th>
                <th>Start Time</th>
                <th>End Time</th>
            </tr>
        </thead>
        <tbody>
            {{#each shifts}}
            <tr>
                <td>{{this.date}}</td>
                <td class="{{#if this.isMorningStart}}morning{{/if}}">{{this.startTime}}</td>
                <td class="{{#if this.isMorningEnd}}morning{{/if}}">{{this.endTime}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
    {{else}}
    <p>No shifts found</p>
    {{/if}}

    <h2>Employee Documents</h2>
    
    {{#if docError}}
        <p style="color: red;">{{docError}}</p>
    {{/if}}
    
    {{#if docSuccess}}
        <p style="color: green;">{{docSuccess}}</p>
    {{/if}}

    <h3>Upload New Document</h3>
    <p><em>Only PDF files up to 2MB are allowed. Maximum 5 documents per employee.</em></p>
    <form method="POST" action="/employee/{{employee._id}}/documents/upload" enctype="multipart/form-data">
        <input type="file" name="document" accept=".pdf,application/pdf" required>
        <br><br>
        <button type="submit">Upload Document</button>
    </form>

    <h3>Uploaded Documents</h3>
    {{#if documents.length}}
    <table border="1">
        <thead>
            <tr>
                <th>File Name</th>
                <th>Size</th>
                <th>Uploaded</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {{#each documents}}
            <tr>
                <td>{{this.originalName}}</td>
                <td>{{this.fileSize}} bytes</td>
                <td>{{this.uploadedAt}}</td>
                <td>
                    <a href="/documents/download/{{this._id}}">Download</a>
                    &nbsp;|&nbsp;
                    <form method="POST" action="/documents/delete/{{this._id}}" style="display: inline;">
                        <button type="submit" onclick="return confirm('Are you sure you want to delete this document?')">Delete</button>
                    </form>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
    {{else}}
    <p>No documents uploaded yet.</p>
    {{/if}}

    <p><a href="/">Back to Employee List</a></p>
</body>
</html>
